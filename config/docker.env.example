# Metis Docker environment — copy to .env and fill secrets
# DO NOT commit .env to version control

# Coordinator API key (required in production)
METIS_API_KEY=change-me-coordinator-key
# Legacy alias also supported:
# COGNITIVE_API_KEY=change-me-coordinator-key

# Worker node bearer tokens
METIS_NODE_A_KEY=change-me-node-a-key
METIS_NODE_B_KEY=change-me-node-b-key

# Optional HMAC signing for inter-node RPC
# METIS_HMAC_SECRET=change-me-hmac-secret

# External LLM API (default stack without local-models profile)
# Uncomment to route nodes to cloud APIs instead of Ollama:
# OPENAI_API_KEY=sk-...
# METIS_BASE_URL=https://api.openai.com/v1
# METIS_BASE_MODEL=gpt-4o-mini

# Node identity (set per service in compose; shown for reference)
# NODE_ID=node-a
# METIS_NODE_PORT=8443

# Coordinator bind
# METIS_COORDINATOR_PORT=8080

# Redis (optional profile: redis)
# REDIS_URL=redis://redis:6379/0

# With local-models profile, add to .env:
# OLLAMA_HOST=ollama:11434
# OLLAMA_BASE_URL=http://ollama:11434/v1
# METIS_BASE_URL=http://ollama:11434/v1
