# Append to metis/deploy/nginx.conf after certbot issued skopos.modelmarket.dev

server {
  listen 443 ssl;
  http2 on;
  server_name skopos.modelmarket.dev;
  ssl_certificate     /etc/letsencrypt/live/skopos.modelmarket.dev/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/skopos.modelmarket.dev/privkey.pem;
  ssl_protocols TLSv1.2 TLSv1.3;
  ssl_ciphers HIGH:!aNULL:!MD5;
  add_header Strict-Transport-Security "max-age=31536000" always;

  location = /healthz {
    proxy_pass http://127.0.0.1:8502/healthz;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
  }

  # Floating AI assistant backend (chat) — same-origin so the browser widget
  # reaches it without CORS. Auth is a short-lived HMAC token per session.
  location /agent/ {
    proxy_pass http://127.0.0.1:8502;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_read_timeout 120;
  }

  location / {
    proxy_pass http://127.0.0.1:8501;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_read_timeout 86400;
  }
}
